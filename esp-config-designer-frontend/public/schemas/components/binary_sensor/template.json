{
  "id": "binary_sensor.template",
  "domain": "binary_sensor",
  "platform": "template",
  "helpUrl": "https://esphome.io/components/binary_sensor/template/",
  "extends": "base_binary_sensor.json",
  "fields": [
    {
      "key": "name",
      "placeholder": "Sensor Name",
      "type": "text",
      "required": true,
      "lvl": "simple"
    },
    {
      "key": "state_source",
      "type": "select",
      "required": true,
      "lvl": "simple",
      "default": "lambda",
      "options": [
        "lambda",
        "condition"
      ]
    },
    {
      "key": "lambda",
      "type": "lambda",
      "required": false,
      "lvl": "simple",
      "dependsOn": {
        "key": "state_source",
        "value": "lambda"
      }
    },
    {
      "key": "condition",
      "type": "yaml",
      "required": false,
      "lvl": "simple",
      "dependsOn": {
        "key": "state_source",
        "value": "condition"
      }
    }
  ]
}
