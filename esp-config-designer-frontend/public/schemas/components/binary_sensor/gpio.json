{
  "id": "binary_sensor.gpio",
  "domain": "binary_sensor",
  "platform": "gpio",
  "requires": [],
  "helpUrl": "https://esphome.io/components/binary_sensor/gpio/",
  "extends": "base_binary_sensor.json",
  "fields": [
    {
      "key": "pin",
      "type": "gpio",
      "required": true,
      "lvl": "simple",
      "helpUrl": "https://esphome.io/guides/configuration-types#pin-schema"
    },
    {
      "key": "name",
      "placeholder": "Binary Sensor Name",
      "type": "text",
      "required": false,
      "lvl": "simple"
    },
    {
      "key": "use_interrupt",
      "type": "boolean",
      "required": false,
      "lvl": "normal"
    },
    {
      "key": "interrupt_type",
      "type": "select",
      "required": false,
      "lvl": "normal",
      "default": "ANY",
      "options": [
        "ANY",
        "RISING",
        "FALLING"
      ]
    }
  ]
}
