{
  "id": "binary_sensor.pn532",
  "domain": "binary_sensor",
  "platform": "pn532",
  "helpUrl": "https://esphome.io/components/binary_sensor/pn532/",
  "extends": "base_binary_sensor.json",
  "embedded": [
    {
      "key": "hub",
      "logicalDomain": "pn532",
      "domainBy": "bus",
      "domainMap": {
        "spi": "pn532_spi",
        "i2c": "pn532_i2c"
      },
      "emitAs": "map",
      "singleton": true,
      "merge": "first"
    }
  ],
  "requirements": [
    {
      "require": "bus:spi",
      "when": {
        "key": "bus",
        "value": "spi"
      }
    },
    {
      "require": "bus:i2c",
      "when": {
        "key": "bus",
        "value": "i2c"
      }
    }
  ],
  "fields": [
    {
      "key": "bus",
      "label": "transport",
      "type": "select",
      "required": true,
	  "emitYAML": "never",
      "lvl": "simple",
      "set_global": "pn532_bus",
      "default": "spi",
      "options": [
        "spi",
        "i2c"
      ]
    },
    {
      "key": "hub",
      "label": "Hub settings",
      "type": "object",
      "required": false,
      "lvl": "simple",
      "emitYAML": "never",
      "extends": "hub_pn532.json"
    },
    {
      "key": "pn532_id",
      "type": "id_ref",
      "required": true,
      "lvl": "simple",
      "emitYAML": "never",
      "domain": "pn532",
      "allowSelfReference": true,
      "default": "pn532_component"
    },
    {
      "key": "uid",
      "type": "text",
      "required": true,
      "lvl": "simple",
      "placeholder": "74-10-37-94"
    }
  ]
}
