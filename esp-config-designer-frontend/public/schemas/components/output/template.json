{
  "id": "output.template",
  "domain": "output",
  "platform": "template",
  "helpUrl": "https://esphome.io/components/output/template/",
  "extends": "base_output.json",
  "fields": [
    {
      "key": "type",
      "type": "select",
      "required": true,
      "lvl": "simple",
	  "default": "binary",
      "options": [
        "binary",
        "float"
      ]
    },
    {
      "key": "write_action",
      "type": "list",
      "required": true,
      "lvl": "simple",
      "note": "The action receives the template output state as the lambda variable state.",
      "item": {
        "type": "object",
        "fields": [],
        "extends": "base_actions.json"
      },
      "wrapThen": true
    },
    {
      "key": "min_power",
      "type": "number",
      "required": false,
      "lvl": "normal",
      "default": 0,
      "dependsOn": {
        "key": "type",
        "value": "float"
      }
    },
    {
      "key": "max_power",
      "type": "number",
      "required": false,
      "lvl": "normal",
      "default": 1,
      "dependsOn": {
        "key": "type",
        "value": "float"
      }
    },
    {
      "key": "zero_means_zero",
      "type": "boolean",
      "required": false,
      "lvl": "normal",
      "default": false,
      "dependsOn": {
        "key": "type",
        "value": "float"
      }
    }
  ]
}
