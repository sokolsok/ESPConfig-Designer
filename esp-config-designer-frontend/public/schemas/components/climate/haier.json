{
  "id": "climate.haier",
  "domain": "climate",
  "platform": "haier",
  "helpUrl": "https://esphome.io/components/climate/haier/",
  "extends": "base_climate.json",
  "requirements": [
    {
      "require": "bus:uart"
    }
  ],
  "fields": [
    {
      "key": "name",
      "placeholder": "Name",
      "type": "text",
      "required": false,
      "lvl": "simple"
    },
    {
      "key": "uart_id",
      "type": "id_ref",
      "required": false,
      "lvl": "normal",
      "domain": "uart"
    },
    {
      "key": "protocol",
      "type": "select",
      "required": false,
      "lvl": "normal",
      "default": "smartair2",
      "options": [
        "hon",
        "smartair2"
      ]
    },
    {
      "key": "wifi_signal",
      "type": "boolean",
      "required": false,
      "lvl": "normal"
    },
    {
      "key": "answer_timeout",
      "type": "duration",
      "required": false,
      "lvl": "normal",
      "default": "200ms"
    },
    {
      "key": "alternative_swing_control",
      "type": "boolean",
      "required": false,
      "lvl": "advanced",
      "dependsOn": {
        "key": "protocol",
        "value": "smartair2"
      }
    },
    {
      "key": "status_message_header_size",
      "type": "number",
      "required": false,
      "lvl": "advanced",
      "dependsOn": {
        "key": "protocol",
        "value": "hon"
      },
      "default": 0
    },
    {
      "key": "control_packet_size",
      "type": "number",
      "required": false,
      "lvl": "advanced",
      "dependsOn": {
        "key": "protocol",
        "value": "hon"
      },
      "default": 10
    },
    {
      "key": "sensors_packet_size",
      "type": "number",
      "required": false,
      "lvl": "advanced",
      "dependsOn": {
        "key": "protocol",
        "value": "hon"
      },
      "default": 22
    },
    {
      "key": "control_method",
      "type": "list",
      "required": false,
      "lvl": "advanced",
      "dependsOn": {
        "key": "protocol",
        "value": "hon"
      },
      "item": {
        "type": "select",
        "options": [
          "MONITOR_ONLY",
          "SET_GROUP_PARAMETERS",
          "SET_SINGLE_PARAMETER"
        ]
      }
    },
    {
      "key": "display",
      "type": "boolean",
      "required": false,
      "lvl": "normal"
    },
    {
      "key": "beeper",
      "type": "boolean",
      "required": false,
      "lvl": "normal",
      "dependsOn": {
        "key": "protocol",
        "value": "hon"
      }
    },
    {
      "key": "supported_modes",
      "type": "list",
      "required": false,
      "lvl": "advanced",
      "item": {
        "type": "select",
        "options": [
          "OFF",
          "HEAT_COOL",
          "COOL",
          "HEAT",
          "DRY",
          "FAN_ONLY"
        ]
      }
    },
    {
      "key": "supported_swing_modes",
      "type": "list",
      "required": false,
      "lvl": "advanced",
      "item": {
        "type": "select",
        "options": [
          "OFF",
          "VERTICAL",
          "HORIZONTAL",
          "BOTH"
        ]
      }
    },
    {
      "key": "supported_presets",
      "type": "list",
      "required": false,
      "lvl": "advanced",
      "note": "Preset values depend on protocol: smartair2 supports AWAY/BOOST/COMFORT, hOn supports AWAY/BOOST/SLEEP.",
      "item": {
        "type": "select",
        "options": [
          "AWAY",
          "BOOST",
          "COMFORT",
          "SLEEP"
        ]
      }
    },
    {
      "key": "on_alarm_start",
      "type": "list",
      "required": false,
      "lvl": "advanced",
      "dependsOn": {
        "key": "protocol",
        "value": "hon"
      },
      "item": {
        "type": "object",
        "fields": [],
        "extends": "base_actions.json"
      },
      "wrapThen": true
    },
    {
      "key": "on_alarm_end",
      "type": "list",
      "required": false,
      "lvl": "advanced",
      "dependsOn": {
        "key": "protocol",
        "value": "hon"
      },
      "item": {
        "type": "object",
        "fields": [],
        "extends": "base_actions.json"
      },
      "wrapThen": true
    },
    {
      "key": "on_status_message",
      "type": "list",
      "required": false,
      "lvl": "advanced",
      "dependsOn": {
        "key": "protocol",
        "value": "hon"
      },
      "item": {
        "type": "object",
        "fields": [],
        "extends": "base_actions.json"
      },
      "wrapThen": true
    }
  ]
}
