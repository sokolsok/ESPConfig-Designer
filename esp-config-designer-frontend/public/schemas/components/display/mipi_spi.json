{
  "id": "display.mipi_spi",
  "domain": "display",
  "platform": "mipi_spi",
  "requires": [
    "spi"
  ],
  "helpUrl": "https://esphome.io/components/display/mipi_spi/",
  "extends": "base_display.json",
  "display_builder": true,
  "displayType": "color",
  "model_meta": {
    "Custom 320x240": {
      "w": 320,
      "h": 240
    },
    "Custom 480x320": {
      "w": 480,
      "h": 320
    }
  },
  "fields": [
    {
      "key": "model",
      "type": "text",
      "required": true,
      "lvl": "simple",
      "placeholder": "ST7789V"
    },
    {
      "key": "bus_mode",
      "type": "select",
      "required": false,
      "lvl": "normal",
      "default": "single",
      "options": [
        "single",
        "quad",
        "octal"
      ]
    },
    {
      "key": "dc_pin",
      "type": "gpio",
      "required": false,
      "lvl": "simple"
    },
    {
      "key": "reset_pin",
      "type": "gpio",
      "required": false,
      "lvl": "normal"
    },
    {
      "key": "cs_pin",
      "type": "gpio",
      "required": false,
      "lvl": "normal"
    },
    {
      "key": "enable_pin",
      "type": "yaml",
      "required": false,
      "lvl": "advanced",
      "placeholder": "GPIOXX\n# or list of pins"
    },
    {
      "key": "brightness",
      "type": "number",
      "required": false,
      "lvl": "normal"
    },
    {
      "key": "color_order",
      "type": "select",
      "required": false,
      "lvl": "normal",
      "default": "bgr",
      "options": [
        "bgr",
        "rgb"
      ]
    },
    {
      "key": "dimensions",
      "type": "yaml",
      "required": false,
      "lvl": "simple",
      "placeholder": "width: 320\nheight: 240"
    },
    {
      "key": "invert_colors",
      "type": "boolean",
      "required": false,
      "lvl": "normal"
    },
    {
      "key": "rotation",
      "type": "select",
      "required": false,
      "lvl": "normal",
      "default": "0",
      "options": [
        "0",
        "90",
        "180",
        "270"
      ]
    },
    {
      "key": "transform",
      "type": "yaml",
      "required": false,
      "lvl": "advanced"
    },
    {
      "key": "color_depth",
      "type": "select",
      "required": false,
      "lvl": "advanced",
      "options": [
        "16",
        "8"
      ]
    },
    {
      "key": "buffer_size",
      "type": "text",
      "required": false,
      "lvl": "advanced",
      "placeholder": "50%"
    },
    {
      "key": "data_rate",
      "type": "text",
      "required": false,
      "lvl": "advanced",
      "placeholder": "40MHz"
    },
    {
      "key": "spi_mode",
      "type": "select",
      "required": false,
      "lvl": "advanced",
      "default": "MODE0",
      "options": [
        "MODE0",
        "MODE3"
      ]
    },
    {
      "key": "auto_clear_enabled",
      "type": "boolean",
      "required": false,
      "lvl": "normal"
    },
    {
      "key": "pages",
      "type": "yaml",
      "required": false,
      "lvl": "advanced"
    },
    {
      "key": "update_interval",
      "type": "duration",
      "required": false,
      "lvl": "normal",
      "default": "5s"
    }
  ]
}
