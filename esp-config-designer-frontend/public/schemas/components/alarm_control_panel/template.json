{
  "id": "alarm_control_panel.template",
  "domain": "alarm_control_panel",
  "platform": "template",
  "helpUrl": "https://esphome.io/components/alarm_control_panel/template/",
  "extends": "base_alarm_control_panel.json",
  "fields": [
    {
      "key": "name",
      "placeholder": "Alarm Panel",
      "type": "text",
      "required": false,
      "lvl": "simple"
    },
    {
      "key": "codes",
      "type": "list",
      "required": false,
      "lvl": "simple",
      "note": "Required when requires_code_to_arm is enabled.",
      "item": {
        "type": "text"
      }
    },
    {
      "key": "requires_code_to_arm",
      "type": "boolean",
      "required": false,
      "lvl": "simple",
      "default": false
    },
    {
      "key": "arming_away_time",
      "type": "duration",
      "required": false,
      "lvl": "simple",
      "default": "0s"
    },
    {
      "key": "arming_home_time",
      "type": "duration",
      "required": false,
      "lvl": "simple",
	  "placeholder": "10s"
    },
    {
      "key": "arming_night_time",
      "type": "duration",
      "required": false,
      "lvl": "simple",
	  "placeholder": "10s"
    },
    {
      "key": "pending_time",
      "type": "duration",
      "required": false,
      "lvl": "simple",
      "default": "0s"
    },
    {
      "key": "trigger_time",
      "type": "duration",
      "required": false,
      "lvl": "normal",
      "default": "0s"
    },
    {
      "key": "custom_config",
      "type": "raw_yaml",
      "required": false,
      "lvl": "advanced"
    },
    {
      "key": "binary_sensors",
      "type": "list",
      "required": false,
      "lvl": "simple",
      "item": {
        "type": "object",
        "fields": [
          {
            "key": "input",
            "type": "id_ref",
            "required": true,
            "lvl": "simple",
            "domain": "binary_sensor"
          },
          {
            "key": "bypass_armed_home",
            "type": "boolean",
            "required": false,
            "lvl": "normal"
          },
          {
            "key": "bypass_armed_night",
            "type": "boolean",
            "required": false,
            "lvl": "normal"
          },
          {
            "key": "bypass_auto",
            "type": "boolean",
            "required": false,
            "lvl": "normal"
          },
          {
            "key": "trigger_mode",
            "type": "select",
            "required": false,
            "lvl": "normal",
            "note": "Choose how this zone triggers: delayed, instant, instant_always, or delayed_follower.",
            "default": "delayed",
            "options": [
              "delayed",
              "instant",
              "instant_always",
              "delayed_follower"
            ]
          },
          {
            "key": "chime",
            "type": "boolean",
            "required": false,
            "lvl": "normal",
            "default": false
          }
        ]
      }
    },
    {
      "key": "restore_mode",
      "type": "select",
      "required": false,
      "lvl": "normal",
      "note": "Template alarm control panel supports only ALWAYS_DISARMED and RESTORE_DEFAULT_DISARMED.",
      "default": "ALWAYS_DISARMED",
      "options": [
        "ALWAYS_DISARMED",
        "RESTORE_DEFAULT_DISARMED"
      ]
    }
  ]
}
