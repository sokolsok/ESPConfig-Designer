{
  "id": "light.fastled",
  "domain": "light",
  "platform": "fastled_clockless",
  "platformByBus": {
    "clockless": "fastled_clockless",
    "spi": "fastled_spi"
  },
  "helpUrl": "https://esphome.io/components/light/fastled/",
  "extends": "base_light.json",
  "fields": [
    {
      "key": "name",
      "type": "text",
      "required": false,
      "lvl": "simple",
	  "placeholder": "Light Name"
    },
    {
      "key": "bus",
      "label": "Variant",
      "type": "select",
      "required": true,
      "lvl": "simple",
      "default": "clockless",
      "options": [
        "clockless",
        "spi"
      ]
    },
    {
      "key": "chipset",
      "type": "select",
      "required": true,
      "lvl": "simple",
	  "default": "NEOPIXEL",
      "options": [
        "NEOPIXEL",
        "WS2811",
        "WS2811_400",
        "WS2812B",
        "WS2812",
        "WS2813",
        "WS2852",
        "APA104",
        "APA106",
        "GW6205",
        "GW6205_400",
        "LPD1886",
        "LPD1886_8BIT",
        "PL9823",
        "SK6812",
        "SK6822",
        "TM1803",
        "TM1804",
        "TM1809",
        "TM1829",
        "UCS1903B",
        "UCS1903",
        "UCS1904",
        "UCS2903",
        "SM16703"
      ]
    },
    {
      "key": "pin",
      "type": "gpio",
      "required": true,
      "lvl": "simple",
      "dependsOn": {
        "key": "bus",
        "value": "clockless"
      },
	  "placeholder": "GPIOXX"
    },
    {
      "key": "data_pin",
      "type": "gpio",
      "required": true,
      "lvl": "simple",
      "dependsOn": {
        "key": "bus",
        "value": "spi"
      },
	  "placeholder": "GPIOXX"
    },
    {
      "key": "clock_pin",
      "type": "gpio",
      "required": true,
      "lvl": "simple",
      "dependsOn": {
        "key": "bus",
        "value": "spi"
      },
	  "placeholder": "GPIOXX"
    },
    {
      "key": "num_leds",
      "type": "number",
      "required": true,
      "lvl": "simple",
	  "placeholder": "30"
    },
    {
      "key": "rgb_order",
      "type": "select",
      "required": false,
      "lvl": "normal",
      "default": "RGB",
      "options": [
        "RGB",
        "RBG",
        "GRB",
        "GBR",
        "BRG",
        "BGR"
      ]
    },
    {
      "key": "max_refresh_rate",
      "type": "duration",
      "required": false,
      "lvl": "normal",
	  "placeholder": "60Hz"
    },
    {
      "key": "data_rate",
      "type": "text",
      "required": false,
      "lvl": "normal",
      "dependsOn": {
        "key": "bus",
        "value": "spi"
      },
      "placeholder": "1MHz"
    }
  ]
}
