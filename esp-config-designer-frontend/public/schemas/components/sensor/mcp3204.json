{
  "id": "sensor.mcp3204",
  "domain": "sensor",
  "platform": "mcp3204",
  "requires": [
    "spi"
  ],
  "helpUrl": "https://esphome.io/components/sensor/mcp3204/",
  "extends": "base_sensor.json",
  "embedded": [
    {
      "key": "hub",
      "domain": "mcp3204",
      "dedupeBy": "id"
    }
  ],
  "fields": [
    {
      "key": "name",
      "placeholder": "Sensor Name",
      "type": "text",
      "required": true,
      "lvl": "simple"
    },
    {
      "key": "hub",
      "label": "Hub settings",
      "type": "object",
      "required": false,
      "lvl": "simple",
      "emitYAML": "never",
      "extends": "hub_mcp3204.json"
    },
    {
      "key": "mcp3204_id",
      "type": "id_ref",
      "required": true,
      "lvl": "simple",
      "domain": "mcp3204",
      "allowSelfReference": true,
      "default": "mcp3204_hub"
    },
    {
      "key": "number",
      "type": "number",
      "required": true,
      "lvl": "simple",
      "placeholder": "0"
    },
    {
      "key": "diff_mode",
      "type": "boolean",
      "required": false,
      "lvl": "normal",
      "default": false
    },
    {
      "key": "update_interval",
      "type": "duration",
      "required": false,
      "lvl": "normal",
      "default": "60s",
      "placeholder": "60s"
    }
  ]
}
