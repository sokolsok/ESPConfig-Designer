{
  "id": "sensor.sdp3x",
  "domain": "sensor",
  "platform": "sdp3x",
  "helpUrl": "https://esphome.io/components/sensor/sdp3x/",
  "extends": "base_sensor.json",
  "requirements": [
    {
      "require": "bus:i2c"
    }
  ],
  "fields": [
    {
      "key": "name",
      "placeholder": "Sensor Name",
      "type": "text",
      "required": true,
      "lvl": "simple"
    },
    {
      "key": "address",
      "type": "address",
      "required": false,
      "lvl": "simple",
      "emitYAML": "always",
      "default": "0x21",
      "placeholder": "0x21"
    },
    {
      "key": "measurement_mode",
      "type": "select",
      "required": false,
      "lvl": "normal",
      "default": "differential_pressure",
      "options": [
        "differential_pressure",
        "mass_flow"
      ]
    },
    {
      "key": "update_interval",
      "type": "duration",
      "required": false,
      "lvl": "simple",
      "placeholder": "60s"
    }
  ]
}
