{
  "id": "sensor.max44009",
  "domain": "sensor",
  "platform": "max44009",
  "helpUrl": "https://esphome.io/components/sensor/max44009/",
  "extends": "base_sensor.json",
  "requirements": [
    {
      "require": "bus:i2c"
    }
  ],
  "fields": [
    {
      "key": "name",
      "placeholder": "Sensor Name",
      "type": "text",
      "required": true,
      "lvl": "simple"
    },
    {
      "key": "address",
      "type": "address",
      "required": false,
	  "emitYAML": "always",
      "lvl": "simple",
      "default": "0x4A"
    },
    {
      "key": "mode",
      "type": "select",
      "required": false,
      "lvl": "normal",
	  "default": "auto",
	  "emitYAML": "always",
      "options": [
        "auto",
        "low_power",
        "continuous"
      ]
    },
    {
      "key": "update_interval",
      "type": "duration",
      "required": false,
      "lvl": "simple",
      "placeholder": "60s"
    }
  ]
}
