{
  "id": "sensor.resistance",
  "domain": "sensor",
  "platform": "resistance",
  "helpUrl": "https://esphome.io/components/sensor/resistance/",
  "extends": "base_sensor.json",
  "fields": [
    {
      "key": "name",
      "placeholder": "Sensor Name",
      "type": "text",
      "required": true,
      "lvl": "simple"
    },
    {
      "key": "sensor",
