{
  "id": "sensor.tsl2561",
  "domain": "sensor",
  "platform": "tsl2561",
  "helpUrl": "https://esphome.io/components/sensor/tsl2561/",
  "extends": "base_sensor.json",
  "requirements": [
    {
      "require": "bus:i2c"
    }
  ],
  "fields": [
    {
      "key": "name",
      "placeholder": "Sensor Name",
      "type": "text",
      "required": true,
      "lvl": "simple"
    },
    {
      "key": "address",
      "type": "address",
      "required": false,
      "lvl": "simple",
      "emitYAML": "always",
      "default": "0x39",
      "placeholder": "0x39"
    },
    {
      "key": "integration_time",
      "type": "select",
      "required": false,
      "lvl": "normal",
      "default": "402ms",
      "options": [
        "14ms",
        "101ms",
        "402ms"
      ]
    },
    {
      "key": "gain",
      "type": "select",
      "required": false,
      "lvl": "normal",
      "default": "1x",
      "options": [
        "1x",
        "16x"
      ]
    },
    {
      "key": "is_cs_package",
      "type": "boolean",
      "required": false,
      "lvl": "normal",
      "default": false
    },
    {
      "key": "update_interval",
      "type": "duration",
      "required": false,
      "lvl": "simple",
      "placeholder": "60s"
    }
  ]
}
