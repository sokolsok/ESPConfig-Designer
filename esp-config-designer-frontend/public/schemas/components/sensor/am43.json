{
  "id": "sensor.am43",
  "domain": "sensor",
  "platform": "am43",
  "requires": [],
  "helpUrl": "https://esphome.io/components/sensor/am43/",
  "embedded": [
    {
      "key": "hub",
      "domain": "ble_client",
      "dedupeBy": "id"
    },
    {
      "key": "ble_tracker",
      "domain": "esp32_ble_tracker",
      "emitAs": "map",
      "singleton": true,
      "alwaysEmit": true,
      "defaultPayload": {},
      "merge": "first"
    }
  ],
  "fields": [
    {
      "key": "update_interval",
      "type": "duration",
      "required": false,
      "lvl": "simple",
      "placeholder": "60s"
    },
    {
      "key": "custom_config",
      "type": "raw_yaml",
      "required": false,
      "lvl": "advanced"
    },
    {
      "key": "hub",
      "label": "Hub settings",
      "type": "object",
      "required": false,
      "lvl": "simple",
      "emitYAML": "never",
      "extends": "hub_ble_client.json"
    },
    {
      "key": "ble_tracker",
      "type": "object",
      "required": false,
      "lvl": "simple",
      "uiHidden": true,
      "emitYAML": "never",
      "extends": "hub_esp32_ble_tracker.json"
    },
    {
      "key": "ble_client_id",
      "type": "id_ref",
      "required": true,
      "lvl": "simple",
      "domain": "ble_client",
      "allowSelfReference": true,
      "default": "ble_client_hub"
    },
    {
      "key": "battery_level",
      "type": "object",
      "required": false,
      "lvl": "simple",
      "extends": "base_sensor.json",
      "fields": []
    },
    {
      "key": "illuminance",
      "type": "object",
      "required": false,
      "lvl": "simple",
      "extends": "base_sensor.json",
      "fields": []
    }
  ]
}
