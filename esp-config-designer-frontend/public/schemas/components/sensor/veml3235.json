{
  "id": "sensor.veml3235",
  "domain": "sensor",
  "platform": "veml3235",
  "helpUrl": "https://esphome.io/components/sensor/veml3235/",
  "extends": "base_sensor.json",
  "requirements": [
    {
      "require": "bus:i2c"
    }
  ],
  "fields": [
    {
      "key": "name",
      "placeholder": "Sensor Name",
      "type": "text",
      "required": true,
      "lvl": "simple"
    },
    {
      "key": "gain",
      "type": "select",
      "required": false,
      "lvl": "advanced",
      "default": "1x",
      "options": [
        "1x",
        "2x",
        "4x"
      ]
    },
    {
      "key": "digital_gain",
      "type": "select",
      "required": false,
      "lvl": "normal",
      "default": "1x",
      "options": [
        "1x",
        "2x"
      ]
    },
    {
      "key": "integration_time",
      "type": "select",
      "required": false,
      "lvl": "normal",
      "default": "50ms",
      "options": [
        "50ms",
        "100ms",
        "200ms",
        "400ms",
        "800ms"
      ]
    },
    {
      "key": "auto_gain",
      "type": "boolean",
      "required": false,
      "lvl": "normal",
      "default": true
    },
    {
      "key": "auto_gain_threshold_high",
      "type": "number",
      "required": false,
      "lvl": "normal",
      "default": 90,
      "placeholder": "90"
    },
    {
      "key": "auto_gain_threshold_low",
      "type": "number",
      "required": false,
      "lvl": "normal",
      "default": 20,
      "placeholder": "20"
    }
  ]
}
