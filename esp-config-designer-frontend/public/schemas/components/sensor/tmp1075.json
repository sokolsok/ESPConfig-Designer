{
  "id": "sensor.tmp1075",
  "domain": "sensor",
  "platform": "tmp1075",
  "helpUrl": "https://esphome.io/components/sensor/tmp1075/",
  "extends": "base_sensor.json",
  "requirements": [
    {
      "require": "bus:i2c"
    }
  ],
  "fields": [
    {
      "key": "name",
      "placeholder": "Sensor Name",
      "type": "text",
      "required": true,
      "lvl": "simple"
    },
    {
      "key": "address",
      "type": "address",
      "required": false,
      "lvl": "simple",
      "emitYAML": "always",
      "default": "0x48",
      "placeholder": "0x48"
    },
    {
      "key": "update_interval",
      "type": "duration",
      "required": false,
      "lvl": "simple",
      "placeholder": "60s"
    },
    {
      "key": "conversion_rate",
      "type": "select",
      "required": false,
      "lvl": "normal",
      "default": "27.5ms",
      "options": [
        "27.5ms",
        "55ms",
        "110ms",
        "220ms"
      ]
    },
    {
      "key": "alert",
      "type": "object",
      "required": false,
      "lvl": "simple",
      "fields": [
        {
          "key": "function",
          "type": "select",
          "required": false,
          "lvl": "simple",
          "default": "comparator",
          "options": [
            "comparator",
            "interrupt"
          ]
        },
        {
          "key": "polarity",
          "type": "select",
          "required": false,
          "lvl": "normal",
          "default": "active_high",
          "options": [
            "active_high",
            "active_low"
          ]
        },
        {
          "key": "limit_low",
          "type": "number",
          "required": false,
          "lvl": "normal",
          "default": -128,
          "placeholder": "-128"
        },
        {
          "key": "limit_high",
          "type": "number",
          "required": false,
          "lvl": "normal",
          "default": 127.9375,
          "placeholder": "127.9375"
        },
        {
          "key": "fault_count",
          "type": "number",
          "required": false,
          "lvl": "simple",
          "default": 1,
          "placeholder": "1"
        }
      ],
      "extends": "base_sensor.json"
    }
  ]
}
