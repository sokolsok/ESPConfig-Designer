{
  "id": "sensor.mopeka_std_check",
  "domain": "sensor",
  "platform": "mopeka_std_check",
  "helpUrl": "https://esphome.io/components/sensor/mopeka_std_check/",
  "embedded": [
    {
      "key": "ble_tracker",
      "domain": "esp32_ble_tracker",
      "emitAs": "map",
      "singleton": true,
      "alwaysEmit": true,
      "defaultPayload": {},
      "merge": "first"
    }
  ],
  "fields": [
    {
      "key": "ble_tracker",
      "type": "object",
      "required": false,
      "lvl": "simple",
      "uiHidden": true,
      "emitYAML": "never",
      "extends": "hub_esp32_ble_tracker.json"
    },
    {
      "key": "mac_address",
      "type": "text",
      "required": true,
      "lvl": "simple"
    },
    {
      "key": "tank_type",
      "type": "select",
      "required": true,
      "lvl": "simple",
      "default": "NORTH_AMERICA_20LB_VERTICAL",
      "options": [
        "NORTH_AMERICA_20LB_VERTICAL",
        "NORTH_AMERICA_30LB_VERTICAL",
        "NORTH_AMERICA_40LB_VERTICAL",
        "EUROPE_6KG",
        "EUROPE_11KG",
        "EUROPE_14KG",
        "CUSTOM"
      ]
    },
    {
      "key": "custom_distance_full",
      "type": "text",
      "required": false,
      "lvl": "normal",
      "placeholder": "40cm",
      "dependsOn": {
        "key": "tank_type",
        "value": "CUSTOM"
      }
    },
    {
      "key": "custom_distance_empty",
      "type": "text",
      "required": false,
      "lvl": "normal",
      "placeholder": "32mm",
      "dependsOn": {
        "key": "tank_type",
        "value": "CUSTOM"
      }
    },
    {
      "key": "propane_butane_mix",
      "type": "select",
      "required": false,
      "lvl": "normal",
      "default": "100%",
      "options": [
        "100%",
        "80%",
        "20%",
        "0%"
      ]
    },
    {
      "key": "level",
      "required": false,
      "lvl": "simple",
      "type": "object",
      "extends": "base_sensor.json",
      "fields": []
    },
    {
      "key": "distance",
      "required": false,
      "lvl": "simple",
      "type": "object",
      "extends": "base_sensor.json",
      "fields": []
    },
    {
      "key": "temperature",
      "type": "object",
      "required": false,
      "lvl": "simple",
      "extends": "base_sensor.json",
      "fields": []
    },
    {
      "key": "battery_level",
      "required": false,
      "lvl": "simple",
      "type": "object",
      "extends": "base_sensor.json",
      "fields": []
    }
  ]
}
