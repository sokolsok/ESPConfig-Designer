{
  "id": "sensor.ble_rssi",
  "domain": "sensor",
  "platform": "ble_rssi",
  "helpUrl": "https://esphome.io/components/sensor/ble_rssi/",
  "extends": "base_sensor.json",
  "embedded": [
    {
      "key": "ble_tracker",
      "domain": "esp32_ble_tracker",
      "emitAs": "map",
      "singleton": true,
      "alwaysEmit": true,
      "defaultPayload": {},
      "merge": "first"
    }
  ],
  "fields": [
    {
      "key": "name",
      "placeholder": "Sensor Name",
      "type": "text",
      "required": true,
      "lvl": "simple"
    },
    {
      "key": "ble_tracker",
      "type": "object",
      "required": false,
      "lvl": "simple",
      "uiHidden": true,
      "emitYAML": "never",
      "extends": "hub_esp32_ble_tracker.json"
    },
    {
      "key": "mac_address",
      "type": "text",
      "required": false,
      "lvl": "normal",
      "placeholder": "AA:BB:CC:DD:EE:FF",
      "note": "Set exactly one of: mac_address, irk, service_uuid, ibeacon_uuid."
    },
    {
      "key": "irk",
      "type": "text",
      "required": false,
      "lvl": "normal",
      "placeholder": "1234567890abcdef1234567890abcdef"
    },
    {
      "key": "service_uuid",
      "type": "text",
      "required": false,
      "lvl": "normal",
      "placeholder": "11aa"
    },
    {
      "key": "ibeacon_uuid",
      "type": "text",
      "required": false,
      "lvl": "normal",
      "placeholder": "68586f1e-89c2-11eb-8dcd-0242ac130003"
    },
    {
      "key": "ibeacon_major",
      "type": "number",
      "required": false,
      "lvl": "normal",
      "dependsOn": {
        "key": "ibeacon_uuid"
      }
    },
    {
      "key": "ibeacon_minor",
      "type": "number",
      "required": false,
      "lvl": "normal",
      "dependsOn": {
        "key": "ibeacon_uuid"
      }
    }
  ]
}
