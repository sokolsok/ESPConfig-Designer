      "key": "skip_updates",
      "type": "number",
      "required": false,
      "lvl": "normal"
    },
    {
      "key": "force_new_range",
      "type": "boolean",
      "required": false,
      "lvl": "normal"
    },
    {
      "key": "lambda",
      "type": "lambda",
      "required": false,
      "lvl": "advanced"
    },
    {
      "key": "write_lambda",
      "type": "lambda",
      "required": false,
      "lvl": "advanced"
    },
    {
      "key": "use_write_multiple",
      "type": "boolean",
      "required": false,
      "lvl": "normal"
    },
    {
      "key": "optimistic",
      "type": "boolean",
      "required": false,
      "lvl": "normal",
      "default": false
