    {
      "key": "custom_preset",
      "label": "Custom preset",
      "type": "text",
      "templatable": true,
      "required": false,
      "lvl": "normal",
      "placeholder": "movie",
      "dependsOn": {
        "key": "preset_type",
        "value": "custom"
      }
    },
    {
      "key": "fan_mode_type",
      "label": "Fan mode type",
      "type": "select",
      "templatable": false,
      "required": false,
      "lvl": "normal",
