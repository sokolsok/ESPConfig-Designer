{
  "id": "climate.control",
  "fields": [
    {
      "key": "id",
      "label": "Climate",
      "type": "id_ref",
      "required": true,
      "placeholder": "climate_id",
      "domain": "climate",
      "lvl": "normal"
    },
    {
      "key": "mode",
      "label": "Mode",
      "type": "select",
      "templatable": true,
      "required": false,
      "lvl": "normal",
      "options": [
        "OFF",
        "AUTO",
        "HEAT",
        "COOL",
        "HEAT_COOL",
        "FAN_ONLY",
        "DRY"
      ]
    },
    {
      "key": "setpoint_type",
      "label": "Setpoint type",
      "type": "select",
      "templatable": false,
      "required": false,
      "lvl": "normal",
      "default": "single",
      "emitYAML": "never",
      "options": [
        "single",
        "range"
      ]
    },
    {
      "key": "target_temperature",
      "label": "Target temperature",
      "type": "text",
      "templatable": true,
      "required": false,
      "lvl": "normal",
      "placeholder": "21.5",
