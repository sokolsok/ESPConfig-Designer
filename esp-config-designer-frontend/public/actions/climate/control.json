      "options": [
        "ON",
        "OFF",
        "AUTO",
        "LOW",
        "MEDIUM",
        "HIGH",
        "MIDDLE",
        "FOCUS",
        "DIFFUSE",
        "QUIET"
      ]
    },
    {
      "key": "custom_fan_mode",
      "label": "Custom fan mode",
      "type": "text",
      "templatable": true,
      "required": false,
      "lvl": "normal",
      "placeholder": "turbo",
      "dependsOn": {
        "key": "fan_mode_type",
        "value": "custom"
