      "dependsOn": {
        "key": "setpoint_type",
        "value": "single"
      }
    },
    {
      "key": "target_temperature_low",
      "label": "Low target temperature",
      "type": "text",
      "templatable": true,
      "required": false,
      "lvl": "normal",
      "placeholder": "19.0",
      "lambdaPlaceholder": "return 19.0;",
      "dependsOn": {
        "key": "setpoint_type",
        "value": "range"
      }
    },
    {
      "key": "target_temperature_high",
      "label": "High target temperature",
      "type": "text",
      "templatable": true,
      "required": false,
      "lvl": "normal",
      "placeholder": "23.0",
      "lambdaPlaceholder": "return 23.0;",
      "dependsOn": {
        "key": "setpoint_type",
        "value": "range"
      }
    },
    {
      "key": "target_humidity",
      "label": "Target humidity",
      "type": "text",
      "templatable": true,
      "required": false,
      "lvl": "normal",
      "placeholder": "45%",
      "lambdaPlaceholder": "return 45;"
    },
    {
      "key": "preset_type",
      "label": "Preset type",
      "type": "select",
