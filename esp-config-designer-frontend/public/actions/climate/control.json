    {
      "key": "swing_mode",
      "label": "Swing mode",
      "type": "select",
      "templatable": true,
      "required": false,
      "lvl": "normal",
      "options": [
        "OFF",
        "BOTH",
        "VERTICAL",
        "HORIZONTAL"
      ]
    }
