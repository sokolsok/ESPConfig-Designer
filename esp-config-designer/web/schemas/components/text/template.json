{
  "id": "text.template",
  "domain": "text",
  "platform": "template",
  "helpUrl": "https://esphome.io/components/text/template/",
  "extends": "base_text.json",
  "fields": [
    {
      "key": "name",
      "type": "text",
      "required": false,
      "lvl": "simple",
      "placeholder": "Text Name"
    },
    {
      "key": "min_length",
      "type": "number",
      "required": false,
      "lvl": "normal",
      "default": 0
    },
    {
      "key": "max_length",
      "type": "number",
      "required": false,
      "lvl": "normal",
      "default": 255
    },
    {
      "key": "lambda",
      "type": "lambda",
      "required": false,
      "lvl": "normal",
      "placeholder": "return std::string(\"hello\");"
    },
    {
      "key": "set_action",
      "type": "list",
      "required": false,
      "lvl": "normal",
      "note": "The action receives the new text value as x.",
      "item": {
        "type": "object",
        "fields": [],
        "extends": "base_actions.json"
      },
      "wrapThen": true
    },
    {
      "key": "update_interval",
      "type": "duration",
      "required": false,
      "lvl": "normal",
      "default": "60s"
    },
    {
      "key": "optimistic",
      "type": "boolean",
      "required": false,
      "lvl": "normal",
      "default": false
    },
    {
      "key": "restore_value",
      "type": "boolean",
      "required": false,
      "lvl": "normal",
      "default": false
    },
    {
      "key": "initial_value",
      "type": "text",
      "required": false,
      "lvl": "normal",
      "placeholder": "hello"
    }
  ]
}
