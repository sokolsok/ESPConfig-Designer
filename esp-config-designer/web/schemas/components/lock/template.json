{
  "id": "lock.template",
  "domain": "lock",
  "platform": "template",
  "helpUrl": "https://esphome.io/components/lock/template/",
  "extends": "base_lock.json",
  "fields": [
    {
      "key": "name",
      "type": "text",
      "required": false,
      "lvl": "simple",
	  "placeholder": "Lock Name"
    },
    {
      "key": "lambda",
      "type": "lambda",
      "required": false,
      "lvl": "normal"
    },
    {
      "key": "lock_action",
      "type": "list",
      "required": false,
      "lvl": "normal",
      "item": {
        "type": "object",
        "fields": [],
        "extends": "base_actions.json"
      },
      "wrapThen": true
    },
    {
      "key": "unlock_action",
      "type": "list",
      "required": false,
      "lvl": "normal",
      "item": {
        "type": "object",
        "fields": [],
        "extends": "base_actions.json"
      },
      "wrapThen": true
    },
    {
      "key": "open_action",
      "type": "list",
      "required": false,
      "lvl": "advanced",
      "note": "Shown in ESPHome examples, even though the config table focuses on lock_action and unlock_action.",
      "item": {
        "type": "object",
        "fields": [],
        "extends": "base_actions.json"
      },
      "wrapThen": true
    },
    {
      "key": "optimistic",
      "type": "boolean",
      "required": false,
      "lvl": "normal",
      "default": false
    },
    {
      "key": "assumed_state",
      "type": "boolean",
      "required": false,
      "lvl": "normal",
      "default": false
    }
  ]
}
