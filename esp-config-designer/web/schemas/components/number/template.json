{
  "id": "number.template",
  "domain": "number",
  "platform": "template",
  "helpUrl": "https://esphome.io/components/number/template/",
  "extends": "base_number.json",
  "fields": [
    {
      "key": "name",
      "type": "text",
      "required": false,
      "lvl": "simple",
      "placeholder": "Number Name"
    },
    {
      "key": "min_value",
      "type": "number",
      "required": true,
      "lvl": "simple",
      "placeholder": "0"
    },
    {
      "key": "max_value",
      "type": "number",
      "required": true,
      "lvl": "simple",
      "placeholder": "100"
    },
    {
      "key": "step",
      "type": "number",
      "required": true,
      "lvl": "simple",
      "placeholder": "1"
    },
    {
      "key": "lambda",
      "type": "lambda",
      "required": false,
      "lvl": "normal",
      "placeholder": "return id(my_sensor).state;"
    },
    {
      "key": "set_action",
      "type": "list",
      "required": false,
      "lvl": "normal",
      "note": "The action receives the new value as x.",
      "item": {
        "type": "object",
        "fields": [],
        "extends": "base_actions.json"
      },
      "wrapThen": true
    },
    {
      "key": "update_interval",
      "type": "duration",
      "required": false,
      "lvl": "normal",
      "default": "60s"
    },
    {
      "key": "optimistic",
      "type": "boolean",
      "required": false,
      "lvl": "normal",
      "default": false
    },
    {
      "key": "restore_value",
      "type": "boolean",
      "required": false,
      "lvl": "normal",
      "default": false
    },
    {
      "key": "initial_value",
      "type": "number",
      "required": false,
      "lvl": "normal",
      "placeholder": "0"
    }
  ]
}
