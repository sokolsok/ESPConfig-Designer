{
  "id": "fan.tuya",
  "domain": "fan",
  "platform": "tuya",
  "helpUrl": "https://esphome.io/components/fan/tuya/",
  "extends": "base_fan.json",
  "embedded": [
    {
      "key": "hub",
      "domain": "tuya",
      "emitAs": "map",
      "singleton": true,
      "merge": "first"
    }
  ],
  "requirements": [
    {
      "require": "component:tuya"
    },
    {
      "require": "bus:uart"
    }
  ],
  "fields": [
    {
      "key": "hub",
      "label": "Tuya hub",
      "type": "object",
      "required": false,
      "lvl": "simple",
      "emitYAML": "never",
      "extends": "hub_tuya.json"
    },
    {
      "key": "tuya_id",
      "type": "id_ref",
      "required": false,
      "lvl": "simple",
      "domain": "tuya",
      "allowSelfReference": true,
      "emitYAML": "never",
      "default": "tuya_hub"
    },
    {
      "key": "speed_datapoint",
      "type": "number",
      "required": true,
      "lvl": "simple"
    },
    {
      "key": "switch_datapoint",
      "type": "number",
      "required": true,
      "lvl": "simple"
    },
    {
      "key": "oscillation_datapoint",
      "type": "number",
      "required": false,
      "lvl": "normal"
    },
    {
      "key": "direction_datapoint",
      "type": "number",
      "required": false,
      "lvl": "normal"
    },
    {
      "key": "speed_count",
      "type": "number",
      "required": false,
      "lvl": "normal",
      "default": 3
    }
  ]
}
