{
  "id": "media_player.i2s_audio",
  "domain": "media_player",
  "platform": "i2s_audio",
  "helpUrl": "https://esphome.io/components/media_player/i2s_audio/",
  "extends": "base_media_player.json",
  "requirements": [
    {
      "require": "component:i2s_audio"
    }
  ],
  "fields": [
    {
      "key": "name",
      "type": "text",
      "required": false,
      "lvl": "simple",
	  "placeholder": "Player Name"
    },
    {
      "key": "dac_type",
      "type": "select",
      "required": true,
      "lvl": "simple",
      "default": "external",
      "note": "Use external when the I2S bus is paired with an external audio driver configured on the bus itself.",
      "options": [
        "external",
        "internal"
      ]
    },
    {
      "key": "i2s_audio_id",
      "type": "id_ref",
      "required": false,
      "lvl": "simple",
      "domain": "i2s_audio"
    },
    {
      "key": "external_mode",
      "yamlKey": "mode",
      "type": "select",
      "required": false,
      "lvl": "normal",
      "default": "mono",
      "options": [
        "mono",
        "stereo"
      ],
      "dependsOn": {
        "key": "dac_type",
        "value": "external"
      }
    },
    {
      "key": "internal_mode",
      "yamlKey": "mode",
      "type": "select",
      "required": true,
      "lvl": "normal",
      "options": [
        "left",
        "right",
        "stereo"
      ]
      ,
      "dependsOn": {
        "key": "dac_type",
        "value": "internal"
      }
    },
    {
      "key": "i2s_dout_pin",
      "type": "gpio",
      "required": true,
      "lvl": "simple",
      "dependsOn": {
        "key": "dac_type",
        "value": "external"
      },
	  "placeholder": "GPIOXX"
    },
    {
      "key": "mute_pin",
      "type": "gpio",
      "required": false,
      "lvl": "normal",
      "dependsOn": {
        "key": "dac_type",
        "value": "external"
      },
	  "placeholder": "GPIOXX"
    },
    {
      "key": "i2s_comm_fmt",
      "type": "select",
      "required": false,
      "lvl": "advanced",
      "default": "msb",
      "options": [
        "msb",
        "lsb"
      ],
      "dependsOn": {
        "key": "dac_type",
        "value": "external"
      }
    }
  ]
}
