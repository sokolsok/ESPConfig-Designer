{
  "id": "sensor.stts22h",
  "domain": "sensor",
  "platform": "stts22h",
  "helpUrl": "https://esphome.io/components/sensor/stts22h/",
  "extends": "base_sensor.json",
  "requirements": [
    {
      "require": "bus:i2c"
    }
  ],
  "fields": [
    {
      "key": "name",
      "placeholder": "Sensor Name",
      "type": "text",
      "required": true,
      "lvl": "simple"
    },
    {
      "key": "i2c_id",
      "type": "id_ref",
      "required": false,
      "lvl": "normal",
      "domain": "sensor"
    },
    {
      "key": "address",
      "type": "select",
      "required": false,
      "lvl": "simple",
      "emitYAML": "always",
      "default": "0x3C",
      "options": [
        "0x38",
        "0x3C",
        "0x3E",
        "0x3F"
      ]
    },
    {
      "key": "update_interval",
      "type": "duration",
      "required": false,
      "lvl": "simple",
      "placeholder": "60s"
    }
  ]
}
