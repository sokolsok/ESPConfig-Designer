{
  "id": "sensor.binary_sensor_map",
  "domain": "sensor",
  "platform": "binary_sensor_map",
  "helpUrl": "https://esphome.io/components/sensor/binary_sensor_map/",
  "extends": "base_sensor.json",
  "fields": [
    {
      "key": "name",
      "placeholder": "Sensor Name",
      "type": "text",
      "required": true,
      "lvl": "simple"
    },
    {
      "key": "type",
      "type": "select",
      "required": true,
      "lvl": "simple",
	  "default": "BAYESIAN",
      "options": [
        "BAYESIAN",
        "GROUP",
        "SUM"
      ]
    },
    {
      "key": "channels",
      "type": "list",
      "required": true,
      "lvl": "simple",
      "dependsOn": {
        "key": "type",
        "values": [
          "GROUP",
          "SUM"
        ]
      },
      "item": {
        "type": "object",
        "fields": [
          {
            "key": "binary_sensor",
            "type": "id_ref",
            "required": true,
            "lvl": "simple",
            "domain": "binary_sensor"
          },
          {
            "key": "value",
            "type": "number",
            "required": true,
            "lvl": "simple"
          }
        ]
      }
    },
    {
      "key": "prior",
      "type": "number",
      "required": false,
      "lvl": "simple",
      "dependsOn": {
        "key": "type",
        "value": "BAYESIAN"
      }
    },
    {
      "key": "observations",
      "type": "list",
      "required": true,
      "lvl": "simple",
      "dependsOn": {
        "key": "type",
        "value": "BAYESIAN"
      },
      "item": {
        "type": "object",
        "fields": [
          {
            "key": "binary_sensor",
            "type": "id_ref",
            "required": true,
            "lvl": "simple",
            "domain": "binary_sensor"
          },
          {
            "key": "prob_given_true",
            "type": "number",
            "required": true,
            "lvl": "simple"
          },
          {
            "key": "prob_given_false",
            "type": "number",
            "required": true,
            "lvl": "simple"
          }
        ]
      }
    }
  ]
}
