{
  "id": "sensor.integration",
  "domain": "sensor",
  "platform": "integration",
  "helpUrl": "https://esphome.io/components/sensor/integration/",
  "extends": "base_sensor.json",
  "fields": [
    {
      "key": "name",
      "placeholder": "Sensor Name",
      "type": "text",
      "required": true,
      "lvl": "simple"
    },
    {
      "key": "sensor",
      "type": "id_ref",
      "required": true,
      "lvl": "simple",
      "domain": "sensor"
    },
    {
      "key": "time_unit",
      "type": "select",
      "required": true,
      "lvl": "simple",
	  "default": "min",
      "options": [
        "ms",
        "s",
        "min",
        "h",
        "d"
      ]
    },
    {
      "key": "integration_method",
      "type": "select",
      "required": false,
      "lvl": "normal",
      "default": "trapezoid",
      "options": [
        "trapezoid",
        "left",
        "right"
      ]
    },
    {
      "key": "restore",
      "type": "boolean",
      "required": false,
      "lvl": "normal"
    }
  ]
}
