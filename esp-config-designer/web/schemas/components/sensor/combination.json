{
  "id": "sensor.combination",
  "domain": "sensor",
  "platform": "combination",
  "helpUrl": "https://esphome.io/components/sensor/combination/",
  "extends": "base_sensor.json",
  "fields": [
    {
      "key": "name",
      "placeholder": "Sensor Name",
      "type": "text",
      "required": true,
      "lvl": "simple"
    },
    {
      "key": "type",
      "type": "select",
      "required": true,
      "lvl": "simple",
      "set_global": "combination_type",
      "default": "LINEAR",
      "options": [
        "KALMAN",
        "LINEAR",
        "MAXIMUM",
        "MEAN",
        "MEDIAN",
        "MINIMUM",
        "MOST_RECENTLY_UPDATED",
        "RANGE",
        "SUM"
      ]
    },
    {
      "key": "process_std_dev",
      "type": "number",
      "required": false,
      "lvl": "normal",
	  "placeholder": "0.000277",
      "dependsOn": {
        "key": "type",
        "value": "KALMAN"
      }
    },
    {
      "key": "sources",
      "type": "list",
      "required": true,
      "lvl": "simple",
      "item": {
        "type": "object",
        "fields": [
          {
            "key": "source",
            "type": "id_ref",
            "required": true,
            "lvl": "simple",
            "domain": "sensor"
          },
          {
            "key": "error",
            "type": "yaml",
            "required": false,
            "lvl": "simple",
            "globalDependsOn": {
              "key": "combination_type",
              "value": "KALMAN"
            }
          },
          {
            "key": "coefficient",
            "type": "yaml",
            "required": false,
            "lvl": "simple",
            "globalDependsOn": {
              "key": "combination_type",
              "value": "LINEAR"
            }
          }
        ]
      }
    },
    {
      "key": "std_dev",
      "type": "object",
      "required": false,
      "lvl": "normal",
      "extends": "base_sensor.json",
      "fields": [],
      "dependsOn": {
        "key": "type",
        "value": "KALMAN"
      }
    }
  ]
}
