{
  "id": "sensor.bh1900nux",
  "domain": "sensor",
  "platform": "bh1900nux",
  "helpUrl": "https://esphome.io/components/sensor/bh1900nux/",
  "extends": "base_sensor.json",
  "requirements": [
    {
      "require": "bus:i2c"
    }
  ],
  "fields": [
    {
      "key": "name",
      "placeholder": "Sensor Name",
      "type": "text",
      "required": true,
      "lvl": "simple"
    },
    {
      "key": "address",
      "type": "address",
      "required": false,
	  "emitYAML": "always",
      "lvl": "simple",
      "default": "0x48"
    },
    {
      "key": "update_interval",
      "type": "duration",
      "required": false,
      "lvl": "simple",
      "placeholder": "60s"
    },
    {
      "key": "i2c_id",
      "type": "id_ref",
      "required": false,
      "lvl": "simple",
      "domain": "i2c"
    }
  ]
}
