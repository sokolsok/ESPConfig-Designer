{
  "id": "sensor.homeassistant",
  "domain": "sensor",
  "platform": "homeassistant",
  "helpUrl": "https://esphome.io/components/sensor/homeassistant/",
  "extends": "base_sensor.json",
  "requirements": [
    {
      "require": "protocol:api"
    }
  ],
  "fields": [
    {
      "key": "name",
      "type": "text",
      "required": false,
      "lvl": "simple",
	  "placeholder": "Sensor Name"
    },
    {
      "key": "internal",
      "type": "boolean",
      "required": false,
      "lvl": "normal",
      "default": true
    },
    {
      "key": "entity_id",
      "type": "text",
      "required": true,
      "suppressQuotes": true,
      "lvl": "simple",
      "placeholder": "sensor.example_entity"
    },
    {
      "key": "attribute",
      "type": "text",
      "required": false,
      "lvl": "normal",
      "placeholder": "attribute_name"
    }
  ]
}
