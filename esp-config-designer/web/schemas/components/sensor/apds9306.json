      "default": "18",
      "options": [
        "20",
        "19",
        "18",
        "17",
        "16",
        "13"
      ]
    },
    {
      "key": "measurement_rate",
      "type": "select",
      "required": false,
      "lvl": "normal",
      "default": "100",
      "options": [
        "25",
        "50",
        "100",
        "200",
        "500",
        "1000"
      ]
    },
    {
