{
  "id": "valve.template",
  "domain": "valve",
  "platform": "template",
  "helpUrl": "https://esphome.io/components/valve/template/",
  "extends": "base_valve.json",
  "fields": [
    {
      "key": "name",
      "type": "text",
      "required": false,
      "lvl": "simple",
      "placeholder": "Valve Name"
    },
    {
      "key": "lambda",
      "type": "lambda",
      "required": false,
      "lvl": "simple",
      "placeholder": "return VALVE_OPEN;"
    },
    {
      "key": "open_action",
      "type": "list",
      "required": false,
      "lvl": "simple",
      "item": {
        "type": "object",
        "fields": [],
        "extends": "base_actions.json"
      },
      "wrapThen": true
    },
    {
      "key": "close_action",
      "type": "list",
      "required": false,
      "lvl": "simple",
      "item": {
        "type": "object",
        "fields": [],
        "extends": "base_actions.json"
      },
      "wrapThen": true
    },
    {
      "key": "stop_action",
      "type": "list",
      "required": false,
      "lvl": "simple",
      "item": {
        "type": "object",
        "fields": [],
        "extends": "base_actions.json"
      },
      "wrapThen": true
    },
    {
      "key": "optimistic",
      "type": "boolean",
      "required": false,
      "lvl": "normal",
      "default": false
    },
    {
      "key": "restore_mode",
      "type": "select",
      "required": false,
      "lvl": "normal",
      "default": "NO_RESTORE",
      "options": [
        "NO_RESTORE",
        "RESTORE",
        "RESTORE_AND_CALL"
      ]
    },
    {
      "key": "assumed_state",
      "type": "boolean",
      "required": false,
      "lvl": "advanced",
      "default": false
    },
    {
      "key": "has_position",
      "type": "boolean",
      "required": false,
      "lvl": "advanced",
      "default": false
    },
    {
      "key": "position_action",
      "type": "list",
      "required": false,
      "lvl": "advanced",
      "note": "The action receives the target position as pos.",
      "item": {
        "type": "object",
        "fields": [],
        "extends": "base_actions.json"
      },
      "wrapThen": true,
      "dependsOn": {
        "key": "has_position",
        "value": true
      }
    }
  ]
}
