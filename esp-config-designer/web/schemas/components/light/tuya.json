{
  "id": "light.tuya",
  "domain": "light",
  "platform": "tuya",
  "helpUrl": "https://esphome.io/components/light/tuya/",
  "extends": "base_light.json",
  "embedded": [
    {
      "key": "hub",
      "domain": "tuya",
      "emitAs": "map",
      "singleton": true,
      "merge": "first"
    }
  ],
  "requirements": [
    {
      "require": "component:tuya"
    },
    {
      "require": "bus:uart"
    }
  ],
  "fields": [
    {
      "key": "hub",
      "label": "Tuya hub",
      "type": "object",
      "required": false,
      "lvl": "simple",
      "emitYAML": "never",
      "extends": "hub_tuya.json"
    },
    {
      "key": "tuya_id",
      "type": "id_ref",
      "required": false,
      "lvl": "simple",
      "domain": "tuya",
      "allowSelfReference": true,
      "emitYAML": "never",
      "default": "tuya_hub"
    },
    {
      "key": "dimmer_datapoint",
      "type": "number",
      "required": false,
      "lvl": "simple"
    },
    {
      "key": "min_value_datapoint",
      "type": "number",
      "required": false,
      "lvl": "normal"
    },
    {
      "key": "switch_datapoint",
      "type": "number",
      "required": false,
      "lvl": "simple"
    },
    {
      "key": "color_temperature_datapoint",
      "type": "number",
      "required": false,
      "lvl": "normal"
    },
    {
      "key": "color_datapoint",
      "type": "number",
      "required": false,
      "lvl": "normal"
    },
    {
      "key": "color_type",
      "type": "select",
      "required": false,
      "lvl": "normal",
      "options": [
        "RGB",
        "HSV",
        "RGBHSV"
      ]
    },
    {
      "key": "color_type_lowercase",
      "type": "boolean",
      "required": false,
      "lvl": "advanced",
      "default": false
    },
    {
      "key": "min_value",
      "type": "number",
      "required": false,
      "lvl": "normal",
      "default": 0
    },
    {
      "key": "max_value",
      "type": "number",
      "required": false,
      "lvl": "normal",
      "default": 255
    },
    {
      "key": "color_temperature_max_value",
      "type": "number",
      "required": false,
      "lvl": "normal",
      "default": 255
    },
    {
      "key": "color_temperature_invert",
      "type": "boolean",
      "required": false,
      "lvl": "normal",
      "default": false
    },
    {
      "key": "cold_white_color_temperature",
      "type": "text",
      "required": false,
      "lvl": "normal"
    },
    {
      "key": "warm_white_color_temperature",
      "type": "text",
      "required": false,
      "lvl": "normal"
    }
  ]
}
