{
  "id": "binary_sensor.esp32_touch",
  "domain": "binary_sensor",
  "platform": "esp32_touch",
  "helpUrl": "https://esphome.io/components/binary_sensor/esp32_touch/",
  "extends": "base_binary_sensor.json",
  "embedded": [
    {
      "key": "hub",
      "domain": "esp32_touch",
      "emitAs": "map",
      "singleton": true,
      "merge": "first"
    }
  ],
  "fields": [
    {
      "key": "hub",
      "label": "Hub settings",
      "type": "object",
      "required": false,
      "lvl": "simple",
      "emitYAML": "never",
      "extends": "hub_esp32_touch.json"
    },
    {
      "key": "esp32_touch_id",
      "type": "id_ref",
      "required": true,
      "lvl": "simple",
      "domain": "esp32_touch",
      "allowSelfReference": true,
      "emitYAML": "never",
      "default": "esp32_touch_hub"
    },
    {
      "key": "name",
      "type": "text",
      "required": false,
      "lvl": "simple",
	  "placeholder": "Binary Sensor Name"
    },
    {
      "key": "pin",
      "type": "gpio",
      "required": true,
      "lvl": "simple",
      "placeholder": "GPIOXX",
      "note": "Use a touch-capable pin. ESP32 GPIO4/0/2/15/13/12/14/27/33/32, ESP32-S2/S3 GPIO1-14, ESP32-P4 GPIO2-15."
    },
    {
      "key": "threshold",
      "type": "number",
      "required": true,
      "lvl": "simple",
	  "placeholder": "1000"
    },
    {
      "key": "wakeup_threshold",
      "type": "number",
      "required": false,
      "lvl": "normal",
	  "placeholder": "500"
    }
  ]
}
