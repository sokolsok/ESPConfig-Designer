{
  "id": "binary_sensor.pn532",
  "domain": "binary_sensor",
  "platform": "pn532",
  "helpUrl": "https://esphome.io/components/binary_sensor/pn532/",
  "extends": "base_binary_sensor.json",
  "embedded": [
    {
      "key": "hub_spi",
      "domain": "pn532_spi",
      "dedupeBy": "id"
    },
    {
      "key": "hub_i2c",
      "domain": "pn532_i2c",
      "dedupeBy": "id"
    }
  ],
  "requirements": [
    {
      "require": "bus:spi",
      "when": {
        "key": "bus",
        "value": "spi"
      }
    },
    {
      "require": "bus:i2c",
      "when": {
        "key": "bus",
        "value": "i2c"
      }
    }
  ],
  "fields": [
    {
      "key": "bus",
      "label": "Transport",
      "type": "select",
      "required": true,
      "lvl": "simple",
      "default": "spi",
      "options": [
        "spi",
        "i2c"
      ]
    },
    {
      "key": "hub_spi",
      "label": "Hub settings",
      "type": "object",
      "required": false,
      "lvl": "simple",
      "emitYAML": "never",
      "extends": "hub_pn532_spi.json",
      "dependsOn": {
        "key": "bus",
        "value": "spi"
      }
    },
    {
      "key": "hub_i2c",
      "label": "Hub settings",
      "type": "object",
      "required": false,
      "lvl": "simple",
      "emitYAML": "never",
      "extends": "hub_pn532_i2c.json",
      "dependsOn": {
        "key": "bus",
        "value": "i2c"
      }
    },
    {
      "key": "uid",
      "type": "text",
      "required": true,
      "lvl": "simple",
      "placeholder": "74-10-37-94"
    }
  ]
}
