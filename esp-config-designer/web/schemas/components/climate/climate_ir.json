  "platformByBus": {
    "ballu": "ballu",
    "coolix": "coolix",
    "daikin": "daikin",
    "daikin_arc": "daikin_arc",
    "climate_ir_lg": "climate_ir_lg",
    "daikin_brc": "daikin_brc",
    "delonghi": "delonghi",
    "emmeti": "emmeti",
    "fujitsu_general": "fujitsu_general",
    "gree": "gree",
    "heatpumpir": "heatpumpir",
    "hitachi_ac344": "hitachi_ac344",
    "hitachi_ac424": "hitachi_ac424",
    "midea_ir": "midea_ir",
    "mitsubishi": "mitsubishi",
    "noblex": "noblex",
    "tcl112": "tcl112",
    "toshiba": "toshiba",
    "whirlpool": "whirlpool",
    "whynter": "whynter"
    ,"yashima": "yashima",
    "zhlt01": "zhlt01"
  },
  "helpUrl": "https://esphome.io/components/climate/climate_ir/",
  "extends": "base_climate.json",
  "embedded": [
    {
      "key": "transmitter_hub",
      "domain": "remote_transmitter",
      "dedupeBy": "id",
      "selectLabel": "Select Transmitter hub"
    }
  ],
  "fields": [
    {
      "key": "name",
      "placeholder": "Name",
      "type": "text",
      "required": false,
      "lvl": "simple"
    },
    {
      "key": "bus",
      "label": "IR Platform",
      "type": "select",
      "required": true,
      "lvl": "simple",
      "default": "climate_ir_lg",
      "options": [
        "ballu",
        "coolix",
        "daikin",
        "daikin_arc",
        "climate_ir_lg",
        "daikin_brc",
        "delonghi",
        "emmeti",
        "fujitsu_general",
        "gree",
        "heatpumpir",
        "hitachi_ac344",
        "hitachi_ac424",
        "midea_ir",
        "mitsubishi",
        "noblex",
        "tcl112",
        "toshiba",
        "whirlpool",
        "whynter"
        ,"yashima",
        "zhlt01"
      ]
    },
    {
      "key": "sensor",
      "type": "id_ref",
      "required": false,
      "lvl": "normal",
      "domain": "sensor"
    },
    {
      "key": "humidity_sensor",
      "type": "id_ref",
      "required": false,
      "lvl": "normal",
      "domain": "sensor"
    },
    {
      "key": "supports_cool",
      "type": "boolean",
      "required": false,
      "lvl": "normal",
      "default": true
    },
    {
      "key": "supports_heat",
      "type": "boolean",
      "required": false,
      "lvl": "normal",
      "default": true
    },
    {
      "key": "receiver_id",
      "type": "id_ref",
      "required": false,
      "lvl": "advanced",
      "domain": "remote_receiver"
    },
    {
      "key": "transmitter_hub",
      "label": "Transmitter hub",
      "type": "object",
      "required": false,
      "lvl": "simple",
      "emitYAML": "never",
      "extends": "hub_remote_transmitter.json"
    },
    {
      "key": "transmitter_id",
      "type": "id_ref",
      "required": true,
      "lvl": "simple",
      "domain": "remote_transmitter"
    },
    {
      "key": "model",
      "type": "text",
      "required": false,
      "lvl": "normal",
      "note": "Required for Gree models. Optional for Toshiba and Whirlpool.",
      "dependsOn": {
        "key": "bus",
        "values": [
          "gree",
          "toshiba",
          "whirlpool"
        ]
      },
      "placeholder": "gree: generic/yan/yaa/yac/yac1fb9/yx1ff/yag; toshiba: GENERIC/RAC-PT1411HWRU-C/RAC-PT1411HWRU-F/RAS-2819T; whirlpool: DG11J1-3A/DG11J1-04"
    },
    {
      "key": "protocol",
      "type": "text",
      "required": false,
      "lvl": "normal",
      "note": "Required when IR Platform is heatpumpir. Use one of the documented HeatpumpIR protocol names from ESPHome docs.",
      "dependsOn": {
        "key": "bus",
        "value": "heatpumpir"
      },
      "placeholder": "panasonic_dke, mitsubishi_fa, samsung_aqv, toshiba, zhlt01, ..."
    },
    {
      "key": "use_fahrenheit",
      "type": "boolean",
      "required": false,
      "lvl": "normal",
      "default": false,
      "dependsOn": {
        "key": "bus",
        "values": [
          "daikin_brc",
          "midea_ir",
          "whynter"
        ]
      }
    },
    {
      "key": "set_fan_mode",
      "type": "select",
      "required": false,
      "lvl": "normal",
      "dependsOn": {
        "key": "bus",
        "value": "mitsubishi"
      },
      "options": [
        "3levels",
        "4levels",
        "quiet_4levels"
      ]
    },
    {
      "key": "supports_dry",
      "type": "boolean",
      "required": false,
      "lvl": "normal",
      "default": false,
      "dependsOn": {
        "key": "bus",
        "value": "mitsubishi"
      }
    },
    {
      "key": "supports_fan_only",
      "type": "boolean",
      "required": false,
      "lvl": "normal",
      "default": false,
      "dependsOn": {
        "key": "bus",
        "value": "mitsubishi"
      }
    },
    {
      "key": "horizontal_default",
      "type": "select",
      "required": false,
      "lvl": "normal",
      "dependsOn": {
        "key": "bus",
        "value": "mitsubishi"
      },
      "options": [
        "left",
        "middle-left",
        "middle",
        "middle-right",
        "right",
        "auto"
      ]
    },
    {
      "key": "vertical_default",
      "type": "select",
      "required": false,
      "lvl": "normal",
      "dependsOn": {
        "key": "bus",
        "value": "mitsubishi"
      },
      "options": [
        "down",
        "middle-down",
        "middle",
        "middle-up",
        "up",
        "auto"
      ]
    },
    {
      "key": "header_high",
      "type": "duration",
      "required": false,
      "lvl": "advanced",
      "dependsOn": {
        "key": "bus",
        "value": "climate_ir_lg"
      }
    },
    {
      "key": "header_low",
      "type": "duration",
      "required": false,
      "lvl": "advanced",
      "dependsOn": {
        "key": "bus",
        "value": "climate_ir_lg"
      }
    },
    {
      "key": "bit_high",
      "type": "duration",
      "required": false,
      "lvl": "advanced",
      "dependsOn": {
        "key": "bus",
        "value": "climate_ir_lg"
      }
    },
    {
      "key": "bit_one_low",
      "type": "duration",
      "required": false,
      "lvl": "advanced",
      "dependsOn": {
        "key": "bus",
        "value": "climate_ir_lg"
      }
    },
    {
      "key": "bit_zero_low",
      "type": "duration",
      "required": false,
      "lvl": "advanced",
      "dependsOn": {
        "key": "bus",
        "value": "climate_ir_lg"
      }
    }
  ]
}
