{
  "id": "climate.pid",
  "domain": "climate",
  "platform": "pid",
  "helpUrl": "https://esphome.io/components/climate/pid/",
  "extends": "base_climate.json",
  "fields": [
    {
      "key": "sensor",
      "type": "id_ref",
      "required": true,
      "lvl": "simple",
      "placeholder": "temperature_sensor",
      "domain": "sensor"
    },
    {
      "key": "humidity_sensor",
      "type": "id_ref",
      "required": false,
      "lvl": "normal",
      "note": "Humidity sensor is display-only for PID climate and does not affect control behavior.",
      "placeholder": "humidity_sensor",
      "domain": "sensor"
    },
    {
      "key": "default_target_temperature",
      "type": "number",
      "required": true,
      "lvl": "simple",
      "placeholder": "21.5"
    },
    {
      "key": "heat_output",
      "type": "id_ref",
      "required": false,
      "lvl": "normal",
      "note": "Configure at least one of heat_output or cool_output. PID climate expects float-capable outputs.",
      "placeholder": "heater_output",
      "domain": "output"
    },
    {
      "key": "cool_output",
      "type": "id_ref",
      "required": false,
      "lvl": "normal",
      "placeholder": "cooler_output",
      "domain": "output"
    },
    {
      "key": "control_parameters",
      "type": "object",
      "required": true,
      "lvl": "simple",
      "fields": [
        {
          "key": "kp",
          "type": "number",
          "required": true,
          "lvl": "simple",
          "placeholder": "0.9"
        },
        {
          "key": "ki",
          "type": "number",
          "required": false,
          "lvl": "normal",
          "placeholder": "0.01",
          "default": 0
        },
        {
          "key": "kd",
          "type": "number",
          "required": false,
          "lvl": "normal",
          "placeholder": "0.0",
          "default": 0
        },
        {
          "key": "min_integral",
          "type": "number",
          "required": false,
          "lvl": "normal",
          "placeholder": "-1.0",
          "default": -1
        },
        {
          "key": "max_integral",
          "type": "number",
          "required": false,
          "lvl": "normal",
          "placeholder": "1.0",
          "default": 1
        },
        {
          "key": "starting_integral_term",
          "type": "number",
          "required": false,
          "lvl": "advanced",
          "placeholder": "0.0"
        },
        {
          "key": "output_averaging_samples",
          "type": "number",
          "required": false,
          "lvl": "advanced",
          "placeholder": "1",
          "default": 1
        },
        {
          "key": "derivative_averaging_samples",
          "type": "number",
          "required": false,
          "lvl": "advanced",
          "placeholder": "1",
          "default": 1
        }
      ]
    },
    {
      "key": "deadband_parameters",
      "type": "object",
      "required": false,
      "lvl": "advanced",
      "fields": [
        {
          "key": "threshold_low",
          "type": "number",
          "required": true,
          "lvl": "normal",
          "placeholder": "-1.0"
        },
        {
          "key": "threshold_high",
          "type": "number",
          "required": true,
          "lvl": "normal",
          "placeholder": "0.5"
        },
        {
          "key": "kp_multiplier",
          "type": "number",
          "required": false,
          "lvl": "normal",
          "placeholder": "0.05",
          "default": 0
        },
        {
          "key": "ki_multiplier",
          "type": "number",
          "required": false,
          "lvl": "normal",
          "placeholder": "0.0",
          "default": 0
        },
        {
          "key": "kd_multiplier",
          "type": "number",
          "required": false,
          "lvl": "normal",
          "placeholder": "0.0",
          "default": 0
        },
        {
          "key": "deadband_output_averaging_samples",
          "type": "number",
          "required": false,
          "lvl": "advanced",
          "placeholder": "1",
          "default": 1
        }
      ]
    },
    {
      "key": "custom_config",
      "type": "raw_yaml",
      "required": false,
      "lvl": "advanced"
    }
  ]
}
