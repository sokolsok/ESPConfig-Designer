{
  "id": "switch.hbridge",
  "domain": "switch",
  "platform": "hbridge",
  "helpUrl": "https://esphome.io/components/switch/hbridge/",
  "extends": "base_switch.json",
  "fields": [
    {
      "key": "name",
      "type": "text",
      "required": false,
      "lvl": "simple",
      "placeholder": "Bridge Name"
    },
    {
      "key": "on_pin",
      "type": "gpio",
      "required": true,
      "lvl": "simple",
      "placeholder": "GPIOXX"
    },
    {
      "key": "off_pin",
      "type": "gpio",
      "required": true,
      "lvl": "simple",
      "placeholder": "GPIOXX"
    },
    {
      "key": "pulse_length",
      "type": "duration",
      "required": false,
      "lvl": "normal",
      "default": "100ms"
    },
    {
      "key": "wait_time",
      "type": "duration",
      "required": false,
      "lvl": "normal",
      "placeholder": "0ms"
    },
    {
      "key": "optimistic",
      "type": "boolean",
      "required": false,
      "lvl": "normal",
      "default": false
    }
  ]
}
