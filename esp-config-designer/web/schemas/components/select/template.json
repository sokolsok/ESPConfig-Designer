{
  "id": "select.template",
  "domain": "select",
  "platform": "template",
  "helpUrl": "https://esphome.io/components/select/template/",
  "extends": "base_select.json",
  "fields": [
    {
      "key": "name",
      "type": "text",
      "required": false,
      "lvl": "simple",
      "placeholder": "Select Name"
    },
    {
      "key": "lambda",
      "type": "lambda",
      "required": false,
      "lvl": "simple",
      "placeholder": "return std::string(\"Option 1\");"
    },
    {
      "key": "update_interval",
      "type": "duration",
      "required": false,
      "lvl": "simple",
      "placeholder": "60s"
    },
    {
      "key": "optimistic",
      "type": "boolean",
      "required": false,
      "lvl": "simple",
      "default": false
    },
    {
      "key": "restore_value",
      "type": "boolean",
      "required": false,
      "lvl": "normal",
      "default": false
    },
    {
      "key": "initial_option",
      "type": "text",
      "required": false,
      "lvl": "normal",
      "placeholder": "Option 1"
    },
    {
      "key": "options",
      "type": "list",
      "required": true,
      "lvl": "simple",
      "item": {
        "type": "text",
		"suppressQuotes": true,
        "placeholder": "Option 1"
      }
    },
    {
      "key": "set_action",
      "type": "list",
      "required": false,
      "lvl": "normal",
      "note": "The action receives the selected option as x and the selected index as i.",
      "item": {
        "type": "object",
        "fields": [],
        "extends": "base_actions.json"
      },
      "wrapThen": true
    }
  ]
}
