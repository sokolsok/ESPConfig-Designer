{
  "id": "select.tuya",
  "domain": "select",
  "platform": "tuya",
  "helpUrl": "https://esphome.io/components/select/tuya/",
  "extends": "base_select.json",
  "embedded": [
    {
      "key": "hub",
      "domain": "tuya",
      "emitAs": "map",
      "singleton": true,
      "merge": "first"
    }
  ],
  "requirements": [
    {
      "require": "component:tuya"
    },
    {
      "require": "bus:uart"
    }
  ],
  "fields": [
    {
      "key": "hub",
      "label": "Tuya hub",
      "type": "object",
      "required": false,
      "lvl": "simple",
      "emitYAML": "never",
      "extends": "hub_tuya.json"
    },
    {
      "key": "tuya_id",
      "type": "id_ref",
      "required": false,
      "lvl": "simple",
      "domain": "tuya",
      "allowSelfReference": true,
      "emitYAML": "never",
      "default": "tuya_hub"
    },
    {
      "key": "name",
      "type": "text",
      "required": false,
      "lvl": "simple",
      "placeholder": "Select Name"
    },
    {
      "key": "enum_datapoint",
      "type": "number",
      "required": false,
      "lvl": "simple",
      "note": "Set enum_datapoint or int_datapoint.",
      "placeholder": "1"
    },
    {
      "key": "int_datapoint",
      "type": "number",
      "required": false,
      "lvl": "simple",
      "placeholder": "2"
    },
    {
      "key": "options",
      "type": "list",
      "required": true,
      "lvl": "simple",
      "item": {
        "type": "object",
        "fields": [
          {
            "key": "key",
            "type": "number",
            "required": true,
            "lvl": "simple",
            "placeholder": "0"
          },
          {
            "key": "value",
            "type": "text",
            "required": true,
            "lvl": "simple",
            "placeholder": "Internal"
          }
        ]
      }
    },
    {
      "key": "optimistic",
      "type": "boolean",
      "required": false,
      "lvl": "normal",
      "default": false
    }
  ]
}
